<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Farmer Helper App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:background="#2E7D32"
            android:padding="12dp" />

        <!-- Crop -->
        <Spinner
            android:id="@+id/crop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp" />

        <!-- Soil -->
        <Spinner
            android:id="@+id/soil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Season -->
        <Spinner
            android:id="@+id/season"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Tips Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Farming Tips"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#388E3C"
            android:padding="8dp"
            android:layout_marginTop="12dp" />

        <!-- Tips Content -->
        <TextView
            android:id="@+id/tips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Use high-yielding varieties.\n• Maintain proper irrigation.\n• Apply balanced fertilizers."
            android:background="#EEEEEE"
            android:padding="10dp" />

        <!-- Buttons Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/call"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Call Officer"
                android:textColor="#FFFFFF"
                android:background="#2E7D32" />

            <Button
                android:id="@+id/sms"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send SMS"
                android:textColor="#FFFFFF"
                android:background="#1976D2" />
        </LinearLayout>

        <!-- Buttons Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/email1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send Email"
                android:textColor="#FFFFFF"
                android:background="#1976D2" />

            <Button
                android:id="@+id/email2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send Email"
                android:textColor="#FFFFFF"
                android:background="#E64A19" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
